{
  "name": "a11yally",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc --project tsconfig.frontend.json && sass public/scss:public/css",
    "start": "node dist/index.js",
    "dev": "concurrently \"npm:watch:scss\" \"npm:watch:ts-front\" \"tsx watch --env-file .env.local src/index.ts\"",
    "scss": "sass public/scss:public/css",
    "watch:scss": "sass --watch public/scss:public/css",
    "watch:ts-front": "tsc --watch --project tsconfig.frontend.json",
    "lint:scss": "stylelint \"public/scss/**/*.scss\"",
    "lint:scss:fix": "stylelint \"public/scss/**/*.scss\" --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@google/generative-ai": "^0.24.1",
    "axe-core": "^4.10.3",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "firebase": "^12.2.1",
    "firebase-tools": "^14.15.2",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.33.0",
    "@eslint/json": "^0.13.1",
    "@eslint/markdown": "^7.1.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "nodemon": "^3.1.10",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "sass": "^1.92.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
