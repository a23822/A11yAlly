{
  "compilerOptions": {
    /* Browser Environment Settings */
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "outDir": "./public/js",

    /* Module Resolution Settings */
    "moduleResolution": "node",
    "esModuleInterop": true,

    /* Code Quality & Strictness */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["public/ts/**/*.ts"]
}
